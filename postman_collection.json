{
  "info": {
    "name": "Task Manager E2E (Dynamic)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.environment.get('username')) {",
          "    const unique = Date.now();",
          "",
          "    const username = 'user_' + unique;",
          "    const password = 'pass_' + unique;",
          "",
          "    const statuses = ['TODO','IN_PROGRESS','DONE'];",
          "    const priorities = ['LOW','MEDIUM','HIGH'];",
          "",
          "    const status = statuses[Math.floor(Math.random() * statuses.length)];",
          "    const priority = priorities[Math.floor(Math.random() * priorities.length)];",
          "",
          "    const today = new Date();",
          "    const startDate = today.toISOString().split('T')[0];",
          "",
          "    const due = new Date();",
          "    due.setDate(today.getDate() + 3);",
          "    const dueDate = due.toISOString().split('T')[0];",
          "",
          "    pm.environment.set('username', username);",
          "    pm.environment.set('password', password);",
          "    pm.environment.set('status', status);",
          "    pm.environment.set('priority', priority);",
          "    pm.environment.set('startDate', startDate);",
          "    pm.environment.set('dueDate', dueDate);",
          "}"
        ]
      }
    }
  ],

  "item": [

    {
      "name": "register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"username\": \"{{username}}\", \"password\": \"{{password}}\", \"role\": \"USER\" }"
        },
        "url": "{{baseUrl}}/api/auth/register"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Register success', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([200,201,400]);",
            "});"
          ]
        }
      }]
    },

    {
      "name": "login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"username\": \"{{username}}\", \"password\": \"{{password}}\" }"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const json = pm.response.json();",
            "",
            "pm.test('Login success', function () {",
            "    pm.expect(pm.response.code).to.eql(200);",
            "});",
            "",
            "if (pm.response.code === 200) {",
            "    pm.environment.set('auth_token', json.accessToken || json.token);",
            "}"
          ]
        }
      }]
    },

    {
      "name": "create-task",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Task {{username}}\",\n  \"description\": \"Generated dynamically\",\n  \"status\": \"{{status}}\",\n  \"priority\": \"{{priority}}\",\n  \"startDate\": \"{{startDate}}\",\n  \"dueDate\": \"{{dueDate}}\",\n  \"assignedUsername\": \"{{username}}\"\n}"
        },
        "url": "{{baseUrl}}/api/tasks"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Task created', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([200,201]);",
            "});"
          ]
        }
      }]
    },

    {
      "name": "dashboard",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "url": "{{baseUrl}}/api/tasks/dashboard"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Dashboard OK', function () {",
            "    pm.expect(pm.response.code).to.eql(200);",
            "});",
            "",
            "pm.test('Has totalTasks', function () {",
            "    const json = pm.response.json();",
            "    pm.expect(json).to.have.property('totalTasks');",
            "});"
          ]
        }
      }]
    }

  ]
}